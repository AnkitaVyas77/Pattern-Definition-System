Project_Path : "ca.mcgill.devops.pipeline"
Pipeline { 
  (Configuration)pipelineConfiguration{
    {
      (String)name
    }
  },
  (Event)triggers*{ 
  },
  (Job)jobs* {
    {
      (String)name,
      (ParameterValue)jobParameterValues* {
        {
          (PipelineKeyword)name: "runs-on:"
        },
        {
          (PipelineKeyword)name: "container:",
          (ParameterValue)subParameters* {
            {
              (PipelineKeyword)name: "image:"
            }
          }
        } 
      },
      (Step)steps* {
        { 
          (PipelineKeyword)actionKeyword: "name:",
          (Script) subSteps*{
            {
              (String)name: "run:"
            }
          }
        }
      }
    }
  }
}