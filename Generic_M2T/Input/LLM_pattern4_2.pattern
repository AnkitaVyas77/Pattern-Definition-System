Project_Path : "ca.mcgill.devops.pipeline" // LOCATION OF THE PROJECT
Pipeline { 
    (Configuration)pipelineConfiguration{
        {
            (String)name
            
        
        }
    },
    (Event)triggers*{ 
        
    },
    
    (Job)jobs* {
        {
            (String)name,
            (ParameterValue)jobParameterValues* {
            
                {
                    (PipelineKeyword)name: "runs-on:"
            
                }
                
                
                
            },
            (Step)steps* {
                {   (PipelineKeyword)actionKeyword: "name:",
                (Script) subSteps*{
                    {
                    (String)name: "run:"
                    }
                }
                }
            }
        
                
        }
    }
        
}






